{
  "expo": {
    "name": "Kombucha Tracker",
    "slug": "kombucha-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "kombuchatracker",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF8F5"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kombuchatracker",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to take photos of your kombucha batches.",
        "NSPhotoLibraryUsageDescription": "Used to add photos to your kombucha batch timeline."
      }
    },
    "android": {
      "package": "com.kombuchatracker",
      "adaptiveIcon": {
        "backgroundColor": "#FAF8F5",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-image-picker",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#C4622D"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
